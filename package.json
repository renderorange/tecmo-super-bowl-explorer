{
    "name": "tecmo-super-bowl-explorer",
    "version": "1.0.0",
    "description": "Stats explorer for Tecmo Super Bowl",
    "main": "app/server.js",
    "scripts": {
        "start": "node app/server.js",
        "start:dev": "node --watch app/server.js",
        "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
        "test:watch": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "test:coverage": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "db:test-setup": "node scripts/generate-test-data.js",
        "test:performance": "NODE_ENV=test jest tests/performance",
        "lint": "node node_modules/eslint/bin/eslint.js . --fix",
        "lint:check": "node node_modules/eslint/bin/eslint.js .",
        "format": "prettier --write \"**/*.{js,mjs,cjs}\"",
        "format:check": "prettier --check \"**/*.{js,mjs,cjs}\""
    },
    "dependencies": {
        "@renderorange/class-types": "^2.0.0",
        "better-sqlite3": "^11.0.0",
        "ejs": "^3.1.10",
        "express": "^4.19.0",
        "morgan": "^1.10.1",
        "node-cache": "^5.1.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "eslint": "^10.0.3",
        "globals": "^16.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.6.2",
        "supertest": "^7.2.2"
    }
}
