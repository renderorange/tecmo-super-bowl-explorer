<%- include("partials/header", { title: "Tecmo Super Bowl Stats", chartJs: false }) %>

<h1>Tecmo Super Bowl Stats Explorer</h1>

<div class="card">
    <h2>Recent Seasons</h2>
    <table>
        <thead>
            <tr><th>Season</th><th>Status</th></tr>
        </thead>
        <tbody>
            <% seasons.forEach(function(s) { %>
            <tr>
                <td><a href="/standings?season=<%= s.id %>">Season <%= s.id %></a></td>
                <td><%= s.status %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<div class="card">
    <h2>League Standings</h2>
    <div class="form-row">
        <select id="season-select">
            <option value="">Select Season</option>
            <% seasons.forEach(function(s) { %>
            <option value="<%= s.id %>">Season <%= s.id %> (<%= s.status %>)</option>
            <% }); %>
        </select>
    </div>
    <div id="stats-container"></div>
</div>

<script>
    document.getElementById("season-select").addEventListener("change", async function() {
        var container = document.getElementById("stats-container");
        if (!this.value) {
            container.innerHTML = "";
            return;
        }
        showLoading(container);
        try {
            var stats = await fetchJson("/api/reports/standings/" + this.value);
            renderStandings(container, stats);
        } catch (e) {
            showError(container, e.message);
        }
    });

    function renderStandings(container, data) {
        if (!data.length) {
            container.innerHTML = "<p>No data available</p>";
            return;
        }
        
        var html = "<table><thead><tr><th>Team</th><th>W</th><th>L</th><th>T</th><th>PF</th><th>PA</th></tr></thead><tbody>";
        data.forEach(function(row) {
            html += "<tr>" +
                "<td><a href='/team/" + row.team_id + "'>" + row.team_name + "</a></td>" +
                "<td>" + row.wins + "</td>" +
                "<td>" + row.losses + "</td>" +
                "<td>" + row.ties + "</td>" +
                "<td>" + formatNumber(row.points_for) + "</td>" +
                "<td>" + formatNumber(row.points_against) + "</td>" +
                "</tr>";
        });
        html += "</tbody></table>";
        container.innerHTML = html;
    }
</script>

<%- include("partials/footer") %>
