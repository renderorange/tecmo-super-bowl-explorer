<%- include("partials/header", { title: "Leaderboard - Tecmo Super Bowl Stats", chartJs: true }) %>

<h1>Player Leaderboard</h1>

<div class="card">
    <div class="form-row">
        <select id="stat-select">
            <% stats.forEach(function(s) { %>
            <option value="<%= s.value %>"><%= s.label %></option>
            <% }); %>
        </select>
        <input type="number" id="limit-input" value="25" min="10" max="100">
    </div>
</div>

<div class="card">
    <div class="chart-container">
        <canvas id="chart"></canvas>
    </div>
</div>

<div id="leaderboard-content">
    <div class="loading">Select a stat to view leaderboard</div>
</div>

<script>
    var chart = null;

    document.getElementById("stat-select").addEventListener("change", loadLeaderboard);
    document.getElementById("limit-input").addEventListener("change", loadLeaderboard);
    loadLeaderboard();

    async function loadLeaderboard() {
        var stat = document.getElementById("stat-select").value;
        var limit = document.getElementById("limit-input").value;
        var container = document.getElementById("leaderboard-content");
        
        showLoading(container);
        try {
            var data = await fetchJson("/api/reports/leaderboard/" + stat + "?limit=" + limit);
            renderChart(data, stat);
            renderTable(container, data, stat);
        } catch (e) {
            showError(container, e.message);
        }
    }

    function renderChart(data, stat) {
        var ctx = document.getElementById("chart").getContext("2d");
        
        if (chart) chart.destroy();
        
        chart = new Chart(ctx, {
            type: "bar",
            data: {
                labels: data.slice(0, 15).map(function(d) { return d.player_name; }),
                datasets: [{
                    label: stat.replace(/_/g, " ").toUpperCase(),
                    data: data.slice(0, 15).map(function(d) { return d.total; }),
                    backgroundColor: "#e94560"
                }]
            },
            options: {
                indexAxis: "y",
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                }
            }
        });
    }

    function renderTable(container, data, stat) {
        if (!data.length) {
            container.innerHTML = "<p>No data available</p>";
            return;
        }

        var statLabel = stat.replace(/_/g, " ");
        var html = "<table><thead><tr><th>Rank</th><th>Player</th><th>Team</th><th>Pos</th><th>" + statLabel + "</th></tr></thead><tbody>";

        data.forEach(function(row, idx) {
            html += "<tr>" +
                "<td>" + (idx + 1) + "</td>" +
                "<td>" + row.player_name + "</td>" +
                "<td>" + row.abbreviation + "</td>" +
                "<td>" + row.position + "</td>" +
                "<td>" + formatNumber(row.total) + "</td>" +
                "</tr>";
        });
        html += "</tbody></table>";

        container.innerHTML = html;
    }
</script>

<%- include("partials/footer") %>
