<%- include("partials/header", { title: "League Standings - Tecmo Super Bowl Stats", chartJs: false }) %>

<h1>League Standings</h1>

<div class="card">
    <div class="form-row">
        <select id="season-select">
            <option value="">Select Season</option>
            <% seasons.forEach(function(s) { %>
            <option value="<%= s.id %>">Season <%= s.id %> (<%= s.status %>)</option>
            <% }); %>
        </select>
        <select id="view-select">
            <option value="league">League Standings</option>
            <option value="division">By Division</option>
        </select>
    </div>
</div>

<div id="standings-content">
    <div class="loading">Select a season to view standings</div>
</div>

<script>
    var urlParams = new URLSearchParams(window.location.search);
    var seasonParam = urlParams.get("season");
    if (seasonParam) {
        document.getElementById("season-select").value = seasonParam;
        loadStandings();
    }

    document.getElementById("season-select").addEventListener("change", loadStandings);
    document.getElementById("view-select").addEventListener("change", loadStandings);

    async function loadStandings() {
        var seasonId = document.getElementById("season-select").value;
        var view = document.getElementById("view-select").value;
        var container = document.getElementById("standings-content");
        
        if (!seasonId) {
            container.innerHTML = '<div class="loading">Select a season to view standings</div>';
            return;
        }

        showLoading(container);
        try {
            var endpoint = view === "division" 
                ? "/api/reports/standings/" + seasonId + "/division"
                : "/api/reports/standings/" + seasonId;
            var data = await fetchJson(endpoint);
            renderStandings(container, data, view);
        } catch (e) {
            showError(container, e.message);
        }
    }

    function renderStandings(container, data, view) {
        if (!data.length) {
            container.innerHTML = "<p>No data available</p>";
            return;
        }

        var currentDivision = "";
        var html = "";

        if (view === "division") {
            data.forEach(function(row) {
                if (row.division !== currentDivision) {
                    if (currentDivision) html += "</tbody></table><br>";
                    currentDivision = row.division;
                    html += "<h3>" + row.conference + " - " + row.division + "</h3>" +
                             "<table><thead><tr><th>#</th><th>Team</th><th>W</th><th>L</th><th>T</th><th>PF</th><th>PA</th><th>Pct</th></tr></thead><tbody>";
                }
                var pct = (row.wins + row.losses + row.ties) > 0 
                    ? (row.wins / (row.wins + row.losses + row.ties)).toFixed(3) 
                    : ".000";
                html += "<tr>" +
                    "<td>" + row.abbreviation + "</td>" +
                    "<td><a href='/team/" + row.team_id + "'>" + row.team_name + "</a></td>" +
                    "<td>" + row.wins + "</td>" +
                    "<td>" + row.losses + "</td>" +
                    "<td>" + row.ties + "</td>" +
                    "<td>" + formatNumber(row.points_for) + "</td>" +
                    "<td>" + formatNumber(row.points_against) + "</td>" +
                    "<td>" + pct + "</td>" +
                    "</tr>";
            });
        } else {
            html = "<table><thead><tr><th>#</th><th>Team</th><th>Conf</th><th>W</th><th>L</th><th>T</th><th>PF</th><th>PA</th><th>Pct</th></tr></thead><tbody>";
            data.forEach(function(row, idx) {
                var pct = (row.wins + row.losses + row.ties) > 0 
                    ? (row.wins / (row.wins + row.losses + row.ties)).toFixed(3) 
                    : ".000";
                html += "<tr>" +
                    "<td>" + (idx + 1) + "</td>" +
                    "<td><a href='/team/" + row.team_id + "'>" + row.team_name + "</a></td>" +
                    "<td>" + row.conference + "</td>" +
                    "<td>" + row.wins + "</td>" +
                    "<td>" + row.losses + "</td>" +
                    "<td>" + row.ties + "</td>" +
                    "<td>" + formatNumber(row.points_for) + "</td>" +
                    "<td>" + formatNumber(row.points_against) + "</td>" +
                    "<td>" + pct + "</td>" +
                    "</tr>";
            });
            html += "</tbody></table>";
        }

        container.innerHTML = html;
    }
</script>

<%- include("partials/footer") %>
